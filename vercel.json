{
  "crons": [
    { "path": "/api/cron/evening-checkin", "schedule": "0 20 * * *" },
    { "path": "/api/cron/morning-checkin", "schedule": "0 8 * * *" }
  ],
  "redirects": [
    { "source": "/pro", "destination": "/pricing", "permanent": false }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(self), geolocation=()" },
        { "key": "Content-Security-Policy", "value": "script-src 'self' 'unsafe-inline'; font-src fonts.googleapis.com fonts.gstatic.com; style-src 'self' 'unsafe-inline' fonts.googleapis.com; img-src 'self' data: https:; default-src 'self'" }
      ]
    }
  ],
  "functions": {
    "pages/api/**": {
      "maxDuration": 60
    }
  }
}
